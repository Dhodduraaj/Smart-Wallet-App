# ==============================================================================
# EXPENSE TRACKER - BACKEND ENVIRONMENT VARIABLES CONFIGURATION (PRODUCTION-READY)
# ==============================================================================
# Copy this file to a '.env' file in the same directory and configure the values.
# Do NOT commit your actual '.env' file containing secrets to version control!

# ------------------------------------------------------------------------------
# 1. SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# The port on which the Spring Boot application will run.
# Cloud platforms (like Render or Railway) inject this variable automatically.
PORT=8081

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (PostgreSQL / Supabase / Neon)
# ------------------------------------------------------------------------------
# JDBC Connection URL for PostgreSQL database. 
# Make sure to set sslmode=require for production environments like Supabase/Neon.
# Example: jdbc:postgresql://<host>:<port>/<db_name>?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/expensetracker?sslmode=disable
DB_USERNAME=postgres
DB_PASSWORD=dhoddudb

# Database DDL Auto-generation strategy.
# Use 'update' for development/staging. For production, set to 'none' or 'validate'.
DB_DDL_AUTO=update

# Show SQL statements in console (true/false)
SHOW_SQL=false

# Hikari Connection Pool Settings
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_MAX_LIFETIME=1800000

# ------------------------------------------------------------------------------
# 3. SMTP MAIL CONFIGURATION (Gmail / SendGrid / Custom SMTP)
# ------------------------------------------------------------------------------
# SMTP server host and port.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Credentials for the email account.
# For Gmail, you MUST use an App Password, NOT your standard account password!
EMAIL_USERNAME=dhodduraajsp@gmail.com
MAIL_PASSWORD=sfllefeutsomlquc

# ------------------------------------------------------------------------------
# 4. SECURITY & JWT (JSON WEB TOKEN)
# ------------------------------------------------------------------------------
# JWT signing secret key. MUST be a strong, base64-encoded key of at least 512 bits!
JWT_SECRET=4zV7A9gK2mN5qR8uW1xY0zC3bV6n9qRvY2t5w8y/B?E(G+KbPeShVkYp3s6v9y$B
# JWT lifespan in milliseconds. Default: 86400000 ms (24 hours)
JWT_EXPIRATION=86400000

# ------------------------------------------------------------------------------
# 5. CORS ORIGINS CONFIGURATION
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins. Use exact URLs without trailing slashes.
# Examples: http://localhost:5173,https://smart-ledger.netlify.app,https://my-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------------------
# 6. FIREBASE CLOUD MESSAGING (HTTP v1 — push notifications)
# ------------------------------------------------------------------------------
# Enable push notifications via Firebase Admin SDK
FIREBASE_ENABLED=true
# Option A (local): absolute path to service account JSON (never commit this file)
FIREBASE_SERVICE_ACCOUNT_PATH=C:/path/to/smart-wallet-firebase-adminsdk.json
# Option B (cloud): paste entire JSON as a single line / multiline env var (Render, Railway)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
